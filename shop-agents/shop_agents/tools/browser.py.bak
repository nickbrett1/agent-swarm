import asyncio
import os
from playwright.async_api import async_playwright
from crewai.tools import BaseTool
from shop_agents.config import settings


class ProductScraperTool(BaseTool):
    name: str = "product_scraper"
    description: str = "Navigates to the shop and returns a list of available products with their names, prices, and IDs."

    def _run(self) -> str:
        """Fetch products synchronously for CrewAI."""
        return asyncio.run(self._fetch_products())

    async def _fetch_products(self) -> str:
        """Perform the actual scraping with Playwright."""
        async with async_playwright() as p:
            browser = await p.chromium.launch(headless=True)
            page = await browser.new_page()
            await page.goto(settings.shop_url)
            await page.wait_for_load_state("load")

            # Extract products by looking for elements that contain a 'Buy Now' button
            products = await page.evaluate('''() => {
                const buttons = Array.from(document.querySelectorAll('button')).filter(b => b.innerText.includes('Buy Now'));
                return buttons.map(button => {
                    let container = button.parentElement;
                    // Move up to find the product card container
                    while (container && container.tagName !== 'BODY' && container.childElementCount < 3) {
                        container = container.parentElement;
                    }
                    return container ? container.innerText : '';
                }).filter(text => text.length > 0).join('\\n---\\n');
            }''')

            if not products:
                products = await page.inner_text('body')

            await browser.close()
            return products


class PurchaseTool(BaseTool):
    name: str = "purchase_tool"
    description: str = "Initiates a purchase for a product. Provide the product name or ID as input."

    def _run(self, product_identifier: str) -> str:
        """Simulate clicking buy and handling Stripe Checkout."""
        return asyncio.run(self._initiate_purchase(product_identifier))

    async def _initiate_purchase(self, product_identifier: str) -> str:
        async with async_playwright() as p:
            browser = await p.chromium.launch(headless=True)
            context = await browser.new_context(viewport={'width': 1280, 'height': 720})
            page = await context.new_page()
            page.set_default_timeout(30000)
            
            print(f"Purchasing product: {product_identifier}")
            await page.goto(settings.shop_url)
            await page.wait_for_load_state("load")

            try:
                # 1. Find the product container
                container = page.locator("div").filter(has_text=product_identifier).filter(has=page.get_by_role("button", name="Buy Now"))
                if await container.count() > 0:
                    target_button = container.last.get_by_role("button", name="Buy Now").first
                else:
                    buy_buttons = page.get_by_role("button", name="Buy Now")
                    target_button = None
                    for i in range(await buy_buttons.count()):
                        btn = buy_buttons.nth(i)
                        try:
                            parent_text = await btn.evaluate("el => el.closest('div').innerText")
                            if product_identifier.lower() in parent_text.lower():
                                target_button = btn
                                break
                        except:
                            continue
                    if not target_button:
                        target_button = buy_buttons.first

                if not target_button or await target_button.count() == 0:
                     return f"Could not find Buy Now button for {product_identifier}"

                print(f"Found button, clicking...")
                await target_button.scroll_into_view_if_needed()
                await target_button.click(force=True)
                
                # 2. Wait for navigation to Stripe
                print("Waiting for Stripe Checkout...")
                stripe_reached = False
                for i in range(40):
                    if "checkout.stripe.com" in page.url:
                        stripe_reached = True
                        break
                    await asyncio.sleep(0.5)

                if stripe_reached:
                    print("Reached Stripe Checkout. Filling info...")
                    await page.wait_for_load_state("load")
                    
                    # Fill email
                    email_field = page.get_by_label("Email").or_(page.locator('input[name="email"]'))
                    await email_field.first.fill("agent@example.com")
                    
                    # Fill Card Details
                    print("Filling card details...")
                    
                    # Define selectors for the card fields
                    card_selectors = 'input#cardNumber, input[name="cardnumber"], input[placeholder*="1234"], input[aria-label*="Card number"]'
                    expiry_selectors = 'input#cardExpiry, input[name="exp-date"], input[placeholder*="MM"], input[aria-label*="Expiration"]'
                    cvc_selectors = 'input#cardCvc, input[name="cvc"], input[placeholder*="CVC"], input[aria-label*="CVC"]'
                    
                    async def fill_field(selectors, value, name):
                        # 1. Try main page first
                        field = page.locator(selectors).first
                        if await field.is_visible():
                            await field.fill(value)
                            return True
                        
                        # 2. Try frames with likely Stripe titles
                        stripe_frames = page.frame_locator('iframe[title*="Secure"], iframe[name*="Stripe"]')
                        field = stripe_frames.locator(selectors).first
                        if await field.is_visible():
                            await field.fill(value)
                            return True

                        # 3. Last resort: check every single frame
                        for frame in page.frames:
                            try:
                                field = frame.locator(selectors).first
                                if await field.is_visible():
                                    await field.fill(value)
                                    return True
                            except:
                                continue
                        return False

                    # Fill the sensitive fields
                    if not await fill_field(card_selectors, settings.stripe_test_card, "Card Number"):
                        print("Warning: Could not find Card Number field")
                    if not await fill_field(expiry_selectors, settings.stripe_test_expiry, "Expiry"):
                        print("Warning: Could not find Expiry field")
                    if not await fill_field(cvc_selectors, settings.stripe_test_cvc, "CVC"):
                        print("Warning: Could not find CVC field")
                    
                    # Name on card
                    name_on_card = page.locator('input#billingName, input[name="name"]').or_(page.get_by_label("Full name on card")).or_(page.get_by_label("Name on card"))
                    await name_on_card.first.fill("Agent Shopper")

                    # Small delay to ensure button is enabled
                    await asyncio.sleep(2)
                    
                    print("Submitting payment...")
                    # Try to find the pay button more flexibly
                    pay_button = page.get_by_role("button", name="Pay").or_(page.locator('button[type="submit"]')).or_(page.locator('button:has-text("Pay")'))
                    await pay_button.first.click()
                    
                    # Wait for success redirect
                    print("Waiting for success redirect...")
                    for _ in range(20):
                        if "success" in page.url.lower() or "thank" in page.url.lower() or settings.shop_url not in page.url:
                            if "checkout.stripe.com" not in page.url:
                                break
                        await asyncio.sleep(1)

                    final_url = page.url
                    print(f"Purchase finished. Final URL: {final_url}")
                    await browser.close()
                    return f"Successfully processed payment. Final page: {final_url}"
                else:
                    url = page.url
                    await page.screenshot(path="scripts/shop_snapshot.png")
                    await browser.close()
                    return f"Failed to reach Stripe Checkout. Current URL: {url}"
            except Exception as e:
                try:
                    await page.screenshot(path="scripts/shop_error.png")
                except:
                    pass
                await browser.close()
                return f"Error during purchase process: {str(e)}"
