{
	"name": "agent-swarm",
	"main": "src/index.js",
	"compatibility_date": "2026-05-30",
	"compatibility_flags": [
		"nodejs_compat_v2"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"observability": {
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": true,
			"persist": true
		}
	}
}
