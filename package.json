{
  "name": "agent-swarm",
  "version": "0.1.0",
  "description": "An autonomous e-commerce agent system powered by Cloudflare Workers AI, Browser Rendering, and the Cloudflare Agents SDK.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "./scripts/run-wrangler-dev.sh",
    "deploy": "wrangler deploy",
    "config": "./scripts/setup-wrangler-config.sh",
    "test": "vitest run --coverage",
    "test:integration": "node scripts/test-agent.js",
    "limits": "node scripts/get-limits.cjs"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.6.0",
    "@cloudflare/playwright": "^1.3.0",
    "@cloudflare/puppeteer": "latest",
    "agents": "latest",
    "dotenv": "^16.4.5",
    "ipaddr.js": "^2.4.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "wrangler": "4.103.0"
  },
  "overrides": {
    "zod": "4.4.3",
    "jsondiffpatch": "^0.7.6",
    "esbuild": "^0.28.1",
    "ai": "^5.0.52"
  }
}
