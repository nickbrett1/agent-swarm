{
  "name": "agent-swarm",
  "version": "0.1.0",
  "description": "An autonomous e-commerce agent system powered by Cloudflare Workers AI, Browser Rendering, and the Cloudflare Agents SDK.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "./scripts/run-wrangler-dev.sh",
    "deploy": "wrangler deploy",
    "config": "./scripts/setup-wrangler-config.sh",
    "test": "vitest run --coverage",
    "test:integration": "node scripts/test-agent.js"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "2.5.9",
    "@cloudflare/playwright": "^1.3.0",
    "@cloudflare/puppeteer": "latest",
    "agents": "latest",
    "dotenv": "^16.4.5",
    "ipaddr.js": "^2.4.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.8",
    "zod": "3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.4.5",
    "wrangler": "4.95.0"
  },
  "overrides": {
    "zod": "3.25.76"
  }
}
