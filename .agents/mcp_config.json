{
  "mcpServers": {
    "svelte": {
      "serverUrl": "https://mcp.svelte.dev/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp"
      ]
    },
    "sonarqube": {
      "command": "npx",
      "args": [
        "-y",
        "sonarqube-mcp-server"
      ],
      "env": {
        "SONARQUBE_TOKEN": "$SONARQUBE_TOKEN",
        "SONARQUBE_ORGANIZATION": "bem"
      }
    },
    "circleci": {
      "command": "npx",
      "args": [
        "-y",
        "@circleci/mcp-server-circleci"
      ],
      "env": {
        "CIRCLECI_TOKEN": "$CIRCLECI_TOKEN",
        "CIRCLE_API_TOKEN": "$CIRCLE_API_TOKEN"
      }
    }
  },
  "security": {
    "environmentVariableRedaction": {
      "allowed": [
        "NANOBANANA_GEMINI_API_KEY",
        "GEMINI_API_KEY",
        "GOOGLE_API_KEY"
      ]
    }
  }
}
